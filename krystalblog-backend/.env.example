# KrystalBlog Backend Environment Variables

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=krystalblog
DB_USERNAME=root
DB_PASSWORD=root

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka
KAFKA_SERVERS=localhost:9092

# JWT
JWT_SECRET=krystalblog-jwt-secret-key-must-be-at-least-256-bits-long-for-hs256

# Upload
UPLOAD_PATH=./uploads
